{
  "extends": "./tsconfig.paths.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./src",
    "outDir": "./dist",
    "sourceMap": false,
    "skipLibCheck": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strict": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "tsBuildInfoFile": "./dist/tsconfig.src.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "src/lib/tiling"],
  "references": [{ "path": "./tsconfig.tiling.json" }]
}
