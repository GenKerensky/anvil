{
  "extends": "./tsconfig.gjs-base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist/.types/integration",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "composite": true,
    "types": ["jasmine"]
  },
  "include": [
    "test/integration/runner.js",
    "test/integration/specs/**/*.js",
    "test/lib/shared-commands.js",
    "test/types/gjs-test-globals.d.ts",
    "test/types/gnome-shell-modules.d.ts"
  ]
}
