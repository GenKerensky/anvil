# Anvil GNOME Shell Extension — E2E Test Container
# Parameterised by FEDORA_VERSION (default: 44)
#
# Build examples:
#   podman build --build-arg FEDORA_VERSION=44 -t anvil-test-pod:fedora-44 -f Containerfile .
#   podman build --build-arg FEDORA_VERSION=43 -t anvil-test-pod:fedora-43 -f Containerfile .
#   podman build --build-arg FEDORA_VERSION=42 -t anvil-test-pod:fedora-42 -f Containerfile .
#
# Supported versions:
#   44 → GNOME Shell 50  (primary)
#   43 → GNOME Shell 49
#   42 → GNOME Shell 48
#
# Strategy: gnome-shell --headless --wayland
#
#   gnome-shell --headless --wayland brings up a Wayland compositor with a
#   virtual framebuffer — no Xvfb, no DRM, no GPU required. This is what
#   GNOME Shell's own CI uses, and it is the only compositor mode that works
#   in a container without real hardware.
#
#   GNOME 50 / mutter 50.1 removed the --nested flag (previously used to run
#   the compositor inside Xvfb for xdotool/ImageMagick keyboard and pixel
#   testing). Therefore keyboard-driven keybinding tests and pixel-level
#   visual assertions are not feasible in the container — all tests use
#   D-Bus methods, gsettings, and Shell.Eval.
#
#   The session requires several D-Bus services not present in a minimal
#   container. These are provided by python-dbusmock stubs defined in
#   start-session.sh, following the pattern used by gnome-shell's CI.

ARG FEDORA_VERSION=44
FROM fedora:${FEDORA_VERSION}

# ---------------------------------------------------------------------------
# System packages
# ---------------------------------------------------------------------------
RUN dnf install -y --setopt=install_weak_deps=False \
    # GNOME Shell and compositor
    gnome-shell \
    mutter \
    gnome-extensions-app \
    gnome-text-editor \
    adwaita-icon-theme \
    gsettings-desktop-schemas \
    # D-Bus
    dbus-daemon \
    dbus-tools \
    # GLib utilities (gsettings, glib-compile-schemas, gdbus)
    glib2 \
    glib2-devel \
    # Python D-Bus mocking — stubs for AccountsService, UPower, NM, etc.
    python3 \
    python3-dbus \
    python3-dbusmock \
    python3-gobject \
    # Keyboard simulation via wtype (zwp_virtual_keyboard_v1)
    wtype \
    # Screenshot capture via grim (wlr-screencopy protocol)
    grim \
    # Xvfb + xdotool + ImageMagick are installed for future use but are not
    # currently usable — GNOME 50 removed the --nested flag needed for them.
    xorg-x11-server-Xvfb \
    xdotool \
    ImageMagick \
    # Scripting utilities
    jq \
    procps-ng \
    util-linux \
    which \
    findutils \
    # Privilege escalation and systemd init
    sudo \
    systemd \
    systemd-udev \
 && dnf clean all \
 && rm -rf /var/cache/dnf

# ---------------------------------------------------------------------------
# Non-root user: gnomeshell (UID 1000)
# ---------------------------------------------------------------------------
RUN useradd \
      --uid 1000 \
      --gid wheel \
      --create-home \
      --home-dir /home/gnomeshell \
      --shell /bin/bash \
      gnomeshell \
 && echo "gnomeshell ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/gnomeshell \
 && chmod 0440 /etc/sudoers.d/gnomeshell \
 && chown -R gnomeshell:wheel /home/gnomeshell

# ---------------------------------------------------------------------------
# systemd system unit: gnome-headless.service
#
# A system-level service (not user-level) because systemd-logind fails in
# minimal containers lacking audit and other capabilities. This service:
#   1. Creates XDG_RUNTIME_DIR (/run/user/1000) and sets its ownership
#   2. Runs start-session.sh as the gnomeshell user
#
# start-session.sh starts the session D-Bus at a fixed path, python-dbusmock
# stubs, and gnome-shell --headless --wayland.
#
# NO_AT_BRIDGE suppresses the AT-SPI D-Bus bridge, which is not available
# in a minimal container.
# ---------------------------------------------------------------------------
RUN printf '\
[Unit]\n\
Description=GNOME Shell headless Wayland session\n\
After=dbus-broker.service\n\
After=polkit.service\n\
Requires=dbus-broker.service\n\
\n\
[Service]\n\
Type=simple\n\
User=gnomeshell\n\
Environment=XDG_RUNTIME_DIR=/run/user/1000\n\
Environment=XDG_SESSION_TYPE=wayland\n\
Environment=XDG_SESSION_CLASS=user\n\
Environment=GNOME_SHELL_SESSION_MODE=user\n\
Environment=MUTTER_DEBUG_DUMMY_MODE_SPECS=1920x1080\n\
Environment=NO_AT_BRIDGE=1\n\
Environment=GJS_DEBUG_OUTPUT=stderr\n\
ExecStartPre=!/bin/mkdir -p /run/user/1000\n\
ExecStartPre=!/bin/chown gnomeshell:wheel /run/user/1000\n\
ExecStartPre=!/bin/chmod 0700 /run/user/1000\n\
ExecStart=/usr/local/bin/start-session.sh\n\
Restart=on-failure\n\
RestartSec=3\n\
\n\
[Install]\n\
WantedBy=graphical.target\n\
' > /etc/systemd/system/gnome-headless.service \
 && systemctl enable gnome-headless.service

# ---------------------------------------------------------------------------
# start-session.sh
#
# Starts the session D-Bus at a fixed address, launches D-Bus mock stubs for
# services gnome-shell expects, then starts gnome-shell --headless --wayland.
#
# The mocked services mirror those used by gnome-shell's own GitLab CI:
#   https://gitlab.gnome.org/GNOME/gnome-shell/-/blob/main/tests/
#
# We use a fixed bus address (not dbus-run-session) so that the test harness
# running via podman exec + set-env.sh can reach the same session bus.
# ---------------------------------------------------------------------------
COPY start-session.sh /usr/local/bin/start-session.sh
RUN chmod 0755 /usr/local/bin/start-session.sh

# ---------------------------------------------------------------------------
# Helper scripts (sourced from the test/e2e build context)
# ---------------------------------------------------------------------------
COPY set-env.sh       /usr/local/bin/set-env.sh
COPY wait-user-bus.sh /usr/local/bin/wait-user-bus.sh
RUN chmod 0755 /usr/local/bin/set-env.sh /usr/local/bin/wait-user-bus.sh

# ---------------------------------------------------------------------------
# Boot via systemd so the user session (and user D-Bus socket) starts cleanly
# ---------------------------------------------------------------------------
STOPSIGNAL SIGRTMIN+3
CMD ["/usr/sbin/init"]
