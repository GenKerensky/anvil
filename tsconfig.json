{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "sourceMap": false,
    "skipLibCheck": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strict": true,
    "types": ["vitest/globals"],
    "paths": {
      "gi://Adw": ["./node_modules/@girs/adw-1"],
      "gi://Clutter": ["./node_modules/@girs/clutter-18"],
      "gi://Gdk": ["./node_modules/@girs/gdk-4.0"],
      "gi://Gio": ["./node_modules/@girs/gio-2.0"],
      "gi://GLib": ["./node_modules/@girs/glib-2.0"],
      "gi://GObject": ["./node_modules/@girs/gobject-2.0"],
      "gi://Gtk": ["./node_modules/@girs/gtk-4.0"],
      "gi://Meta": ["./node_modules/@girs/meta-18"],
      "gi://Shell": ["./test/types/gi-shell.d.ts"],
      "gi://St": ["./node_modules/@girs/st-18"],
      "resource:///org/gnome/Shell/Extensions/js/misc/config.js": ["./test/types/prefs-config.d.ts"]
    }
  },
  "include": [
    "ambient.d.ts",
    "test/types/gi-shell.d.ts",
    "test/types/prefs-config.d.ts",
    "test/types/meta-extensions.d.ts"
  ],
  "files": ["extension.ts", "prefs.ts"],
  "exclude": ["node_modules", "dist"]
}
